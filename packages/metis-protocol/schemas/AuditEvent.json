{
  "$defs": {
    "AgentKind": {
      "description": "What kind of agent produced an artifact (PROV ``Agent``).",
      "enum": [
        "connector",
        "parser",
        "extractor",
        "model",
        "skill",
        "maintainer",
        "human",
        "system"
      ],
      "title": "AgentKind",
      "type": "string"
    },
    "Attribution": {
      "additionalProperties": false,
      "description": "Who/what produced an artifact (PROV ``Agent`` + attribution).",
      "properties": {
        "agent": {
          "title": "Agent",
          "type": "string"
        },
        "agent_kind": {
          "$ref": "#/$defs/AgentKind"
        },
        "role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        }
      },
      "required": [
        "agent_kind",
        "agent"
      ],
      "title": "Attribution",
      "type": "object"
    },
    "JsonValue": {},
    "ModelRun": {
      "additionalProperties": false,
      "description": "Metadata for a single LLM call.",
      "properties": {
        "audit_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Audit Hash"
        },
        "cache_hit": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cache Hit"
        },
        "cost_usd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Usd"
        },
        "finished_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finished At"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "input_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "latency_ms": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "model_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Version"
        },
        "output_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Version"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0",
          "pattern": "^\\d+\\.\\d+$",
          "title": "Schema Version",
          "type": "string"
        },
        "sensitivity": {
          "$ref": "#/$defs/Sensitivity"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "task_class": {
          "$ref": "#/$defs/ModelTaskClass"
        }
      },
      "required": [
        "id",
        "task_class",
        "provider",
        "model",
        "sensitivity",
        "started_at"
      ],
      "title": "ModelRun",
      "type": "object"
    },
    "ModelTaskClass": {
      "enum": [
        "parse_assist",
        "segment",
        "extract_claims",
        "extract_entities",
        "extract_events",
        "summarize_episode",
        "consolidate_memory",
        "detect_contradiction",
        "build_foresight",
        "wiki_compile",
        "query_rewrite",
        "query_answer",
        "query_verify",
        "suggest_questions",
        "skill_plan",
        "skill_execute",
        "interpret_command"
      ],
      "title": "ModelTaskClass",
      "type": "string"
    },
    "PermissionScope": {
      "description": "Capabilities a skill (or other actor) can be granted; enforced outside prompts.",
      "enum": [
        "network",
        "filesystem_read",
        "filesystem_write",
        "connector",
        "secrets",
        "outbound_action",
        "model_call",
        "subprocess"
      ],
      "title": "PermissionScope",
      "type": "string"
    },
    "PolicyDecision": {
      "additionalProperties": false,
      "description": "The pure result of a policy check (computed outside prompts).",
      "properties": {
        "allowed": {
          "title": "Allowed",
          "type": "boolean"
        },
        "obligations": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Obligations",
          "type": "array"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string"
        },
        "required_scopes": {
          "default": [],
          "items": {
            "$ref": "#/$defs/PermissionScope"
          },
          "title": "Required Scopes",
          "type": "array"
        }
      },
      "required": [
        "allowed"
      ],
      "title": "PolicyDecision",
      "type": "object"
    },
    "Sensitivity": {
      "description": "Data sensitivity, ordered least to most restrictive (see ``SENSITIVITY_ORDER``).",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "Sensitivity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "One immutable audit record.",
  "properties": {
    "action": {
      "title": "Action",
      "type": "string"
    },
    "actor": {
      "$ref": "#/$defs/Attribution"
    },
    "audit_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Audit Hash"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "model_run": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelRun"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "occurred_at": {
      "format": "date-time",
      "title": "Occurred At",
      "type": "string"
    },
    "payload": {
      "anyOf": [
        {
          "$ref": "#/$defs/JsonValue"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "policy_decision": {
      "anyOf": [
        {
          "$ref": "#/$defs/PolicyDecision"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "prev_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prev Hash"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    },
    "sensitivity": {
      "anyOf": [
        {
          "$ref": "#/$defs/Sensitivity"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "target_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Id"
    },
    "target_kind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Kind"
    },
    "workspace_id": {
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "workspace_id",
    "occurred_at",
    "actor",
    "action"
  ],
  "title": "AuditEvent",
  "type": "object"
}
