{
  "additionalProperties": false,
  "description": "A character range in an artifact/doc \u2014 the unit every claim cites.",
  "properties": {
    "artifact_id": {
      "title": "Artifact Id",
      "type": "string"
    },
    "char_end": {
      "minimum": 0,
      "title": "Char End",
      "type": "integer"
    },
    "char_start": {
      "minimum": 0,
      "title": "Char Start",
      "type": "integer"
    },
    "doc_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Doc Id"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "locator": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Locator"
    },
    "page": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Page"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "id",
    "artifact_id",
    "char_start",
    "char_end"
  ],
  "title": "SourceSpan",
  "type": "object"
}
