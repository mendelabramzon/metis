{
  "$defs": {
    "ClaimRef": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        }
      },
      "required": [
        "claim_id"
      ],
      "title": "ClaimRef",
      "type": "object"
    },
    "ContextSection": {
      "additionalProperties": false,
      "description": "One packed section of context with its supporting evidence.",
      "properties": {
        "claims": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ClaimRef"
          },
          "title": "Claims",
          "type": "array"
        },
        "heading": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Heading"
        },
        "source_spans": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceSpanRef"
          },
          "title": "Source Spans",
          "type": "array"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "ContextSection",
      "type": "object"
    },
    "SourceSpanRef": {
      "additionalProperties": false,
      "description": "Evidence pointer. Carries the owning artifact (and doc) for direct resolution.",
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "doc_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doc Id"
        },
        "source_span_id": {
          "title": "Source Span Id",
          "type": "string"
        }
      },
      "required": [
        "source_span_id",
        "artifact_id"
      ],
      "title": "SourceSpanRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Evidence packed into model-ready context, with a sufficiency estimate.",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "query_id": {
      "title": "Query Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    },
    "sections": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ContextSection"
      },
      "title": "Sections",
      "type": "array"
    },
    "sufficiency": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sufficiency"
    },
    "token_estimate": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Token Estimate"
    }
  },
  "required": [
    "id",
    "query_id"
  ],
  "title": "ContextBundle",
  "type": "object"
}
