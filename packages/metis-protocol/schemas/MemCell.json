{
  "$defs": {
    "AgentKind": {
      "description": "What kind of agent produced an artifact (PROV ``Agent``).",
      "enum": [
        "connector",
        "parser",
        "extractor",
        "model",
        "skill",
        "maintainer",
        "human",
        "system"
      ],
      "title": "AgentKind",
      "type": "string"
    },
    "Attribution": {
      "additionalProperties": false,
      "description": "Who/what produced an artifact (PROV ``Agent`` + attribution).",
      "properties": {
        "agent": {
          "title": "Agent",
          "type": "string"
        },
        "agent_kind": {
          "$ref": "#/$defs/AgentKind"
        },
        "role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Role"
        }
      },
      "required": [
        "agent_kind",
        "agent"
      ],
      "title": "Attribution",
      "type": "object"
    },
    "ClaimRef": {
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        }
      },
      "required": [
        "claim_id"
      ],
      "title": "ClaimRef",
      "type": "object"
    },
    "Derivation": {
      "additionalProperties": false,
      "description": "How an artifact was produced (PROV ``Activity`` + derivation).",
      "properties": {
        "code_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code Version"
        },
        "inputs": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Inputs",
          "type": "array"
        },
        "model_run": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelRun"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "operation": {
          "title": "Operation",
          "type": "string"
        }
      },
      "required": [
        "operation"
      ],
      "title": "Derivation",
      "type": "object"
    },
    "MemCellRef": {
      "additionalProperties": false,
      "properties": {
        "mem_cell_id": {
          "title": "Mem Cell Id",
          "type": "string"
        }
      },
      "required": [
        "mem_cell_id"
      ],
      "title": "MemCellRef",
      "type": "object"
    },
    "MemSceneRef": {
      "additionalProperties": false,
      "properties": {
        "mem_scene_id": {
          "title": "Mem Scene Id",
          "type": "string"
        }
      },
      "required": [
        "mem_scene_id"
      ],
      "title": "MemSceneRef",
      "type": "object"
    },
    "ModelRun": {
      "additionalProperties": false,
      "description": "Metadata for a single LLM call.",
      "properties": {
        "audit_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Audit Hash"
        },
        "cache_hit": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cache Hit"
        },
        "cost_usd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Usd"
        },
        "finished_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finished At"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "input_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "latency_ms": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "model_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Version"
        },
        "output_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Version"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "schema_version": {
          "default": "1.0",
          "pattern": "^\\d+\\.\\d+$",
          "title": "Schema Version",
          "type": "string"
        },
        "sensitivity": {
          "$ref": "#/$defs/Sensitivity"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "task_class": {
          "$ref": "#/$defs/ModelTaskClass"
        }
      },
      "required": [
        "id",
        "task_class",
        "provider",
        "model",
        "sensitivity",
        "started_at"
      ],
      "title": "ModelRun",
      "type": "object"
    },
    "ModelTaskClass": {
      "enum": [
        "parse_assist",
        "segment",
        "extract_claims",
        "extract_entities",
        "extract_events",
        "summarize_episode",
        "consolidate_memory",
        "detect_contradiction",
        "build_foresight",
        "wiki_compile",
        "query_rewrite",
        "query_answer",
        "query_verify",
        "skill_plan",
        "skill_execute"
      ],
      "title": "ModelTaskClass",
      "type": "string"
    },
    "PolicyState": {
      "additionalProperties": false,
      "description": "Policy attributes carried by every artifact and propagated to derivations.",
      "properties": {
        "allow_external_models": {
          "default": true,
          "title": "Allow External Models",
          "type": "boolean"
        },
        "legal_hold": {
          "default": false,
          "title": "Legal Hold",
          "type": "boolean"
        },
        "sensitivity": {
          "$ref": "#/$defs/Sensitivity",
          "default": "internal"
        },
        "tags": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "title": "PolicyState",
      "type": "object"
    },
    "Provenance": {
      "additionalProperties": false,
      "description": "The provenance envelope embedded on every artifact.",
      "properties": {
        "attribution": {
          "$ref": "#/$defs/Attribution"
        },
        "derivation": {
          "anyOf": [
            {
              "$ref": "#/$defs/Derivation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "received_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Received At"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trace Id"
        },
        "workspace_id": {
          "title": "Workspace Id",
          "type": "string"
        }
      },
      "required": [
        "workspace_id",
        "attribution"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "Sensitivity": {
      "description": "Data sensitivity, ordered least to most restrictive (see ``SENSITIVITY_ORDER``).",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted"
      ],
      "title": "Sensitivity",
      "type": "string"
    },
    "SourceSpanRef": {
      "additionalProperties": false,
      "description": "Evidence pointer. Carries the owning artifact (and doc) for direct resolution.",
      "properties": {
        "artifact_id": {
          "title": "Artifact Id",
          "type": "string"
        },
        "doc_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doc Id"
        },
        "source_span_id": {
          "title": "Source Span Id",
          "type": "string"
        }
      },
      "required": [
        "source_span_id",
        "artifact_id"
      ],
      "title": "SourceSpanRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "An episode-like interpreted memory, backed by claims and source spans.",
  "properties": {
    "claims": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ClaimRef"
      },
      "title": "Claims",
      "type": "array"
    },
    "content": {
      "title": "Content",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "occurred_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Occurred At"
    },
    "policy": {
      "$ref": "#/$defs/PolicyState"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "salience": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Salience"
    },
    "scene": {
      "anyOf": [
        {
          "$ref": "#/$defs/MemSceneRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    },
    "source_spans": {
      "items": {
        "$ref": "#/$defs/SourceSpanRef"
      },
      "minItems": 1,
      "title": "Source Spans",
      "type": "array"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "supersedes": {
      "anyOf": [
        {
          "$ref": "#/$defs/MemCellRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "tombstoned_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tombstoned At"
    }
  },
  "required": [
    "id",
    "provenance",
    "policy",
    "created_at",
    "summary",
    "content",
    "source_spans"
  ],
  "title": "MemCell",
  "type": "object"
}
