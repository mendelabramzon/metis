{
  "$defs": {
    "JobState": {
      "enum": [
        "pending",
        "running",
        "succeeded",
        "failed",
        "cancelled",
        "retrying"
      ],
      "title": "JobState",
      "type": "string"
    },
    "JsonValue": {}
  },
  "additionalProperties": false,
  "description": "A unit of background work managed by a ``JobQueue``.",
  "properties": {
    "attempts": {
      "default": 0,
      "title": "Attempts",
      "type": "integer"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "title": "Kind",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/JsonValue"
    },
    "scheduled_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scheduled At"
    },
    "schema_version": {
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    },
    "state": {
      "$ref": "#/$defs/JobState",
      "default": "pending"
    },
    "workspace_id": {
      "title": "Workspace Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "workspace_id",
    "kind",
    "created_at"
  ],
  "title": "Job",
  "type": "object"
}
