# Metis deployment configuration. Copy to `.env` (NOT committed) and fill in.
# Real secrets must come from a secure source (the Stage 14 secret store), never a committed file.

# --- model profile: local | cloud | gpu ---
METIS_MODEL_PROFILE=local

# --- Postgres ---
POSTGRES_PASSWORD=change-me

# --- object store (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# --- gateway auth (dev stand-in; wire to the secret store in production) ---
# `make setup` generates strong values for the change-me fields below + the secret-store key.
METIS_GATEWAY_OPERATOR_TOKEN=change-me-operator
METIS_GATEWAY_USER_TOKEN=change-me-user
METIS_GATEWAY_WORKSPACE_ID=ws_00000000000000000000000000000000

# --- secret-store key (optional, but unlocks a lot) ---
# A Fernet key for the encrypted secret store. The base stack comes up without it; set it to enable
# durable connector secrets (OAuth tokens, TDLib db keys) AND the runtime provider config UI
# (Settings -> Providers), so an operator can set model/Google/Telegram keys without redeploying.
# MUST be the same across the gateway + workers, and STABLE — rotating/losing it makes stored
# secrets unrecoverable. Generate with `make setup -- --cred-key-only`. The Telegram overlay requires
# it. (Compose maps this to METIS_GATEWAY_CRED_STORE_KEY / METIS_INGEST_WORKER_CRED_STORE_KEY.)
# METIS_CRED_STORE_KEY=

# --- cloud profile only: hosted model API key (inject from the secret store) ---
# ANTHROPIC_API_KEY=

# --- gpu profile only: the served model ---
# METIS_GPU_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- local model wiring (optional): answer with a local LLM + local embeddings ---
# Set on the gateway to enable; unset = deterministic extractive answers + stub vectors.
# The local profile sets this to the model-runtime service (pull bge-m3 + gemma4:e4b first).
# METIS_GATEWAY_MODEL_ENDPOINT=http://localhost:11434
# METIS_GATEWAY_CHAT_MODEL=gemma4:e4b
# METIS_GATEWAY_EMBEDDING_MODEL=bge-m3

# --- observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- OpenSSL ARM crypto extensions ---
# Defaults to 0 (software crypto) to avoid a cryptography SIGILL on virtualized ARM (e.g. Docker
# Desktop on Apple Silicon). A no-op on x86. Set to a real capability value only on bare-metal ARM
# where you want hardware crypto and don't hit the fault.
# OPENSSL_ARMCAP=0

# --- Telegram ingestion (opt-in; profiles.telegram.yml) ---
# Requires METIS_CRED_STORE_KEY (see "secret-store key" above — the overlay makes it mandatory).
# Business connected-bot token (the default Telegram transport):
# TELEGRAM_BOT_TOKEN=
# Telegram app credential (https://my.telegram.org) for the opt-in TDLib backfill path:
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
