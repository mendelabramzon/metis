# Gateway service settings (env prefix METIS_GATEWAY_).
# Copy to .env and adjust. Process environment overrides these.
METIS_GATEWAY_HOST=127.0.0.1
METIS_GATEWAY_PORT=8000
METIS_GATEWAY_LOG_LEVEL=INFO

# Single workspace served by this gateway (ws_<32 hex>).
METIS_GATEWAY_WORKSPACE_ID=ws_00000000000000000000000000000000
# Bearer tokens -> scope (dev stand-in; encrypted credentials + SSO are Stage 14).
METIS_GATEWAY_OPERATOR_TOKEN=operator-dev-token
METIS_GATEWAY_USER_TOKEN=user-dev-token
# Optional: directory of skill packages to register at startup.
# METIS_GATEWAY_SKILLS_ROOT=./skills
