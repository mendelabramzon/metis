# Keep the Docker build context small (build context is the repo root).
.git
.venv
**/__pycache__
.mypy_cache
.ruff_cache
.pytest_cache
.hypothesis
.import_linter_cache
htmlcov
coverage.xml
.coverage
**/*.egg-info
# Node: the SPA is built inside the image (deploy/images/gateway.Dockerfile, `web` stage), so a
# local install/build must not leak into the context or shadow the clean `npm ci`.
**/node_modules
apps/web/dist
